#!/usr/bin/env ruby

require 'scout'
require 'scout-ai'
require 'json'
require 'set'
require 'tempfile'

$0 = "scout-ai #{$previous_commands.any? ? $previous_commands * ' ' + ' ' : ''}#{File.basename(__FILE__)}" if defined?($previous_commands) && $previous_commands

options = SOPT.setup <<EOF
Inspect the chat, jobs, agent logs, and token trace behind a Scout-AI chat

$ #{$0} [<options>] <chat>

-h--help Print this help
-c--chat* Chat file to inspect (the positional argument is used by default)
-f--flow Print a compact provenance flow
--dot* Write the flow as Graphviz DOT
-p--plot* Render the flow as svg, png, or pdf
EOF

if options[:help]
  defined?(scout_usage) ? scout_usage : puts(SOPT.doc)
  exit 0
end

Log.severity = options.delete(:log).to_i if options.include?(:log)
input = options.delete(:chat) || ARGV.shift
flow = options.delete(:flow)
dot_file = options.delete(:dot)
plot_file = options.delete(:plot)
raise ParameterException, 'No chat file given' if input.nil? || input.empty?

class LLMInfoReport
  attr_reader :root, :chats, :jobs, :warnings

  def initialize(input)
    @root = resolve_chat(input)
    @chats = {}
    @jobs = {}
    @job_identities = {}
    @job_aliases = {}
    @warnings = []
    @imports = []
    @results = []
    @dependencies = []
    @logs = []
    discover_chat(@root)
  end

  def resolve_chat(input)
    candidates = [input, "#{input}.chat", File.expand_path(input), File.expand_path("#{input}.chat")]
    begin
      candidates << Scout.chats[input].find
      candidates << Scout.chats[input].find_with_extension(:chat).find
    rescue
    end
    candidates.compact.find { |path| File.file?(path.to_s) } ||
      raise(ParameterException, "Chat not found: #{input}")
  end

  def load_chat(path)
    Chat.load(path)
  rescue => e
    @warnings << "Could not read chat #{path}: #{e.message}"
    nil
  end

  def discover_chat(path)
    path = File.expand_path(path.to_s)
    return if @chats.include?(path)
    chat = load_chat(path)
    return if chat.nil?
    @chats[path] = chat

    %w[import continue last].each do |role|
      chat.role_messages(role).each do |message|
        imported = Chat.find_file(message[:content].to_s.strip, path)
        next unless imported && File.file?(imported.to_s)
        imported = File.expand_path(imported.to_s)
        @imports << [imported, path]
        discover_chat(imported)
      end
    end

    chat.jobs.each do |reference|
      job = discover_job(reference)
      @results << [job.path.to_s, path] if job
    end
  end

  # ~/.scout and ~/.rbbt can expose the same persisted result. Keep one
  # canonical Step per Workflow/task/result basename so it appears once in the
  # flow and its mirrored logs are not counted as a second object.
  def job_identity(job, path)
    workflow = job.info[:workflow] || job.info['workflow']
    task = job.info[:task_name] || job.info['task_name']
    workflow && task ? [workflow.to_s, task.to_s, File.basename(path)] : path.split(File::SEPARATOR).last(3)
  end

  def discover_job(reference)
    job = Step === reference ? reference : Step.load(reference)
    physical = File.expand_path(job.path.to_s)
    return @jobs[@job_aliases[physical]] if @job_aliases.include?(physical)

    identity = job_identity(job, physical)
    if canonical = @job_identities[identity]
      @job_aliases[physical] = canonical
      return @jobs[canonical]
    end

    path = physical
    @job_identities[identity] = path
    @job_aliases[physical] = path
    @jobs[path] = job

    job.dependencies.each do |dependency|
      dependency_job = discover_job(dependency)
      @dependencies << [dependency_job.path.to_s, path] if dependency_job
    end

    if job.done? && job.type.to_s == 'chat'
      @results << [path, path]
      discover_chat(path)
    end

    log = job.file('log')
    if log.directory?
      log.glob('**/*.chat').sort.each do |file|
        file = File.expand_path(file.to_s)
        @logs << [path, file]
        discover_chat(file)
      end
    end

    job
  rescue => e
    @warnings << "Could not load job #{reference}: #{e.message}"
    nil
  end

  def trace(chat_list = @chats.values)
    Chat.trace_chats(chat_list)
  end

  def direct_entries(chat_list = @chats.values)
    trace(chat_list).select do |entry|
      meta = entry[:meta]
      next false if meta[:job]
      %w[pt ct tt].any? { |name| meta.include?(name) }
    end
  end

  def token_totals(chat_list = @chats.values)
    direct_entries(chat_list).each_with_object({ pt: 0, ct: 0, tt: 0 }) do |entry, totals|
      meta = entry[:meta]
      %w[pt ct tt].each { |name| totals[name.to_sym] += meta[name].to_i }
    end
  end

  def short_path(path)
    path = File.expand_path(path.to_s)
    home = File.expand_path('~')
    path.start_with?(home + '/') ? "~#{path[home.length..]}" : path
  end

  def roles(chat)
    chat.each_with_object(Hash.new(0)) { |message, counts| counts[message[:role].to_s] += 1 }
  end

  def print_tokens(tokens)
    "prompt=#{tokens[:pt]} completion=#{tokens[:ct]} total=#{tokens[:tt]}"
  end

  def print
    puts 'Chats'
    puts '====='
    @chats.sort.each do |path, chat|
      role_text = roles(chat).sort.collect { |role, count| "#{role}=#{count}" } * ' '
      puts "#{short_path(path)}"
      puts "  messages=#{chat.length} #{role_text}"
      jobs = chat.jobs
      puts "  jobs=#{jobs * ', '}" unless jobs.empty?
    end

    puts
    puts 'Jobs'
    puts '===='
    @jobs.sort.each do |path, job|
      puts "#{short_path(path)}"
      puts "  #{job.info[:workflow]}##{job.info[:task_name]}"
      logs = @logs.select { |source, _| source == path }.collect(&:last)
      puts "  logs=#{logs.length} dependencies=#{job.dependencies.length}"
    end

    root_chat = @chats[File.expand_path(@root.to_s)]
    puts
    puts 'Token usage'
    puts '-----------'
    puts "Root chat: #{print_tokens(token_totals([root_chat]))}"
    puts "All traced chats: #{print_tokens(token_totals)}"
    puts "Trace records: #{trace.length}"

    unless @warnings.empty?
      puts
      puts 'Warnings'
      puts '========'
      @warnings.uniq.each { |warning| puts "- #{warning}" }
    end
  end

  FLOW_COLORS = %w[#dceeff #e8f5df #fff0d6 #f3e2f7 #fde2e2 #e2f2f2 #eeeeee]

  # Job result chats are represented by their job node. Agent logs and external
  # chats remain separate objects because they carry distinct conversation work.
  def flow_nodes
    external = @chats.keys.reject { |path| @jobs.include?(path) || default_answer_log?(path) }
    external.collect { |path| [flow_kind(path), path] } + ordered_jobs.collect { |path| [:job, path] }
  end

  # The standard log/agent.chat of an ask job is its answer-producing agent.
  # Its token usage remains in the job total, so showing it as a separate
  # visual node merely duplicates the primary job node.
  def default_answer_log?(path)
    suffix = '.files/log/agent.chat'
    return false unless path.end_with?(suffix)
    job_path = path.delete_suffix(suffix)
    #job = @jobs[job_path]
    #job && (job.info[:task_name] || job.info['task_name']).to_s == 'ask'
    object_tokens(:job, job_path) == object_tokens(:chat, path)
  end

  def flow_kind(path)
    path.include?('.files/log/') ? :agent : :chat
  end

  def ordered_jobs
    predecessors = Hash.new { |hash, key| hash[key] = [] }
    @dependencies.each { |from, to| predecessors[to] << from if @jobs.include?(from) && @jobs.include?(to) }
    ordered, visiting, visited = [], Set.new, Set.new
    visit = lambda do |path|
      return if visited.include?(path) || visiting.include?(path)
      visiting << path
      predecessors[path].uniq.sort.each { |previous| visit.call(previous) }
      visiting.delete(path)
      visited << path
      ordered << path
    end
    @jobs.keys.sort.each { |path| visit.call(path) }
    ordered
  end

  def flow_edges
    edges = []
    edges.concat(@imports.collect { |from, to| [:chat, from, flow_kind(to), to, :import] })
    edges.concat(@results.reject { |from, to| from == to || flow_kind(to) == :agent }.collect { |from, to| [:job, from, flow_kind(to), to, :result] })
    edges.concat(@dependencies.collect { |from, to| [:job, from, :job, to, :dependency] })
    edges.concat(@logs.reject { |_from, to| default_answer_log?(to) }.collect { |from, to| [:job, from, :agent, to, :log] })
    edges.select { |from_kind, from, to_kind, to, _type| flow_nodes.include?([from_kind, from]) && flow_nodes.include?([to_kind, to]) }.uniq
  end

  def job_name(path)
    job = @jobs[path]
    workflow = job && (job.info[:workflow] || job.info['workflow'])
    task = job && (job.info[:task_name] || job.info['task_name'])
    workflow && task ? "#{workflow}/#{task}" : File.dirname(path).split('/').last(2) * '/'
  end

  def log_name(path)
    job_path, relative = path.split('.files/log/', 2)
    base = job_name(job_path)
    branch = relative.to_s.sub(%r{/agent\.chat\z}, '').sub(/\.chat\z/, '')
    branch = 'agent' if branch.empty? || branch == 'agent'
    if branch.start_with? 'chat'
      "#{branch.sub(/^chats\//,'')}"
    else
      "#{base}/#{branch}"
    end
  end

  def chat_name(path)
    if path =~ %r{/chats/(.+)\z}
      $1.sub(/\.chat\z/, '')
    else
      File.basename(path, '.chat')
    end
  end

  def object_name(kind, path)
    case kind
    when :job then job_name(path)
    when :agent then log_name(path)
    else chat_name(path)
    end
  end

  def object_tokens(kind, path)
    @object_tokens ||= {}
    @object_tokens[path] ||= begin
                              case kind
                              when :job
                                logs = @logs.select { |source, _| source == path }.
                                  collect(&:last).map { |log| @chats[log] }.compact
                                token_totals(logs)[:tt]
                              else
                                chat = @chats[path]
                                chat ? token_totals([chat])[:tt] : 0
                              end
                            end
  end

  def flow_object_id(kind, path)
    return File.basename(path).sub(/^Default_/, '')[0, 8] if kind == :job
    owner = path.split('.files/', 2).first
    return File.basename(owner).sub(/^Default_/, '')[0, 8] if kind == :agent
    Misc.digest(path)[0, 8]
  end

  def short_number(number)
    return format('%.1fM', number / 1_000_000.0) if number >= 1_000_000
    return format('%.1fk', number / 1_000.0) if number >= 1_000
    number.to_i.to_s
  end

  def style_key(kind, path)
    case kind
    when :job then job_name(path)
    when :agent then job_name(path.split('.files/', 2).first)
    else nil
    end
  end

  def flow_colors
    keys = flow_nodes.filter_map { |kind, path| style_key(kind, path) }.uniq.sort
    keys.each_with_index.to_h { |key, index| [key, FLOW_COLORS[index % FLOW_COLORS.length]] }
  end

  def flow_description(kind, path)
    [kind.to_s.capitalize, object_name(kind, path), short_number(object_tokens(kind, path)), flow_object_id(kind, path)]
  end

  def print_flow
    nodes = flow_nodes
    indexes = nodes.each_with_index.to_h { |node, index| [node, index + 1] }
    puts 'Flow'
    puts '===='
    nodes.each do |kind, path|
      type, name, tokens, id = flow_description(kind, path)
      puts format('[%2d] %-5s %-42s %8s %s', indexes[[kind, path]], type, name, tokens, id)
    end
    puts
    flow_edges.each do |from_kind, from, to_kind, to, type|
      puts format('[%2d] --%-10s--> [%2d]', indexes[[from_kind, from]], type, indexes[[to_kind, to]])
    end
  end

  def flow_dot
    nodes = flow_nodes
    ids = nodes.each_with_index.to_h { |node, index| [node, "n#{index}"] }
    colors = flow_colors
    lines = [
      'digraph scout_ai_flow {',
      '  graph [rankdir=LR, bgcolor="white", pad=0.2, nodesep=0.35, ranksep=0.6];',
      '  node [fontname="Helvetica", fontsize=10];',
      '  edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];'
    ]
    nodes.each do |kind, path|
      type, name, tokens, id = flow_description(kind, path)
      label = "#{type}\n#{name}\n#{tokens} tokens  #{id}"
      shape = kind == :job ? 'box' : kind == :agent ? 'component' : 'note'
      color = colors[style_key(kind, path)] || '#f7f7f7'
      lines << "  #{ids[[kind, path]]} [shape=#{shape}, style=\"rounded,filled\", fillcolor=#{JSON.generate(color)}, label=#{JSON.generate(label)}];"
    end
    edge_style = {
      import: 'color="#7a4e9d", label="import"',
      result: 'color="#39804a", penwidth=1.5, label="result"',
      dependency: 'color="#333333", label="dependency"',
      log: 'color="#2864a5", style="dashed", label="log"'
    }
    flow_edges.each do |from_kind, from, to_kind, to, type|
      lines << "  #{ids[[from_kind, from]]} -> #{ids[[to_kind, to]]} [#{edge_style[type]}];"
    end
    lines << '}'
    lines * "\n"
  end

  def write_flow(dot_file: nil, plot_file: nil)
    dot = flow_dot
    Open.write(dot_file, dot) if dot_file
    return unless plot_file

    extension = File.extname(plot_file).sub(/^\./, '').downcase
    extension = 'svg' if extension.empty?
    raise ParameterException, "Unsupported plot format: #{extension}" unless %w[svg png pdf].include?(extension)
    Tempfile.create(['scout-ai-flow', '.dot']) do |source|
      source.write(dot)
      source.flush
      raise ScoutException, 'Graphviz dot failed' unless system('dot', "-T#{extension}", source.path, '-o', plot_file.to_s)
    end
  end
end

report = LLMInfoReport.new(input)
if flow || dot_file || plot_file
  report.print_flow if flow
  report.write_flow(dot_file: dot_file, plot_file: plot_file) if dot_file || plot_file
else
  report.print
end
