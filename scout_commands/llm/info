#!/usr/bin/env ruby

require 'scout'
require 'scout-ai'
require 'json'
require 'set'

$0 = "scout-ai #{$previous_commands.any? ? $previous_commands * ' ' + ' ' : ''}#{File.basename(__FILE__)}" if defined?($previous_commands) && $previous_commands

options = SOPT.setup <<EOF
Report usage and structure information for a Scout-AI chat

$ #{$0} [<options>] <chat>

The report includes the input chat, imported chat files, every referenced ask
Workflow job, and all of its dependency jobs. For each job it reports every
.files/**/agent.chat log. Repeated jobs, logs, token events and tool calls are
deduplicated for aggregate totals.

-h--help Print this help
-c--chat* Chat file to inspect (the positional argument is used by default)
EOF

if options[:help]
  if defined? scout_usage
    scout_usage
  else
    puts SOPT.doc
  end
  exit 0
end

Log.severity = options.delete(:log).to_i if options.include?(:log)

input = options.delete(:chat) || ARGV.shift
raise ParameterException, 'No chat file given' if input.nil? || input.empty?

class LLMInfoReport
  attr_reader :chat_files, :jobs

  def initialize(input)
    @input = resolve_chat(input)
    @chat_files = Set.new
    @jobs = {}
    @seen_sources = Set.new
  end

  def resolve_chat(input)
    candidates = [input, File.expand_path(input)]
    begin
      candidates << Scout.chats[input].find
    rescue
    end
    candidates.compact.find { |path| File.file?(path.to_s) } ||
      raise(ParameterException, "Chat not found: #{input}")
  end

  def messages(path)
    LLM.messages(Open.read(path.to_s))
  rescue Exception => e
    Log.warn "Could not parse chat #{path}: #{e.message}"
    []
  end

  def metadata(messages)
    messages.select { |message| message[:role].to_s == 'meta' }.collect do |message|
      Chat.parse_meta(message[:content].to_s)
    rescue
      nil
    end.compact
  end

  def job_references(messages)
    metadata(messages).flat_map do |meta|
      [meta[:job], meta['job'], meta[:usage_job], meta['usage_job']]
    end.compact.uniq
  end

  def resolve_job(reference)
    reference = reference.to_s
    candidates = [reference, File.expand_path(reference)]
    begin
      candidates << Scout.var.jobs[reference].find
    rescue
    end
    candidates << File.join(File.expand_path('~/.scout/var/jobs'), reference)

    candidates.each do |candidate|
      candidate = candidate.to_s.sub(/\.info$/, '')
      return File.expand_path(candidate) if File.file?(candidate) || File.file?(candidate + '.info')
    end

    # Relocate old job paths by their Workflow/task/result suffix.
    parts = reference.split(File::SEPARATOR)
    if parts.length >= 3
      suffix = File.join(*parts.last(3))
      [File.expand_path('~/.scout/var/jobs'), File.expand_path('~/.rbbt/var/jobs')].each do |root|
        candidate = File.join(root, suffix)
        return candidate if File.file?(candidate) || File.file?(candidate + '.info')
      end
    end

    begin
      step = Step.load(reference)
      candidate = File.expand_path(step.path.to_s) if step
      return candidate if candidate && (File.file?(candidate) || File.file?(candidate + '.info'))
    rescue
    end

    nil
  end

  def ask_job?(path, info = nil)
    info ||= job_info(path)
    info['task_name'].to_s == 'ask' || path.split(File::SEPARATOR).include?('ask')
  end

  def job_info(path)
    info_file = path + '.info'
    File.file?(info_file) ? IndiferentHash.setup(JSON.parse(File.read(info_file))) : IndiferentHash.setup({})
  rescue Exception => e
    Log.warn "Could not read job info #{info_file}: #{e.message}"
    IndiferentHash.setup({})
  end

  def imported_files(path, messages)
    messages.filter_map do |message|
      next unless %w(import continue last).include?(message[:role].to_s)
      Chat.find_file(message[:content].to_s.strip, path)
    rescue
      nil
    end.select { |file| File.file?(file.to_s) }
  end

  def discover
    source_queue = [@input]
    job_queue = []

    until source_queue.empty? && job_queue.empty?
      until source_queue.empty?
        source = File.expand_path(source_queue.shift.to_s)
        next if @seen_sources.include?(source)
        @seen_sources << source

        parsed = messages(source)
        @chat_files << source unless source.include?('.files/') && File.basename(source) == 'agent.chat'
        imported_files(source, parsed).each { |file| source_queue << file }
        job_references(parsed).each { |reference| job_queue << reference }
      end

      until job_queue.empty?
        reference = job_queue.shift
        path = resolve_job(reference)
        next if path.nil? || @jobs.include?(path)

        info = job_info(path)

        logs = Dir.glob(path + '.files/**/agent.chat').select { |file| File.file?(file) }.sort
        @jobs[path] = {info: info, logs: logs}

        Array(info[:dependencies] || info['dependencies']).each { |dependency| job_queue << dependency }

        if File.file?(path)
          parsed = messages(path)
          imported_files(path, parsed).each { |file| source_queue << file }
          job_references(parsed).each { |nested| job_queue << nested }
        end

        logs.each do |log|
          parsed = messages(log)
          imported_files(log, parsed).each { |file| source_queue << file }
          job_references(parsed).each { |nested| job_queue << nested }
        end
      end
    end

    self
  end

  def job_endpoints(info)
    provided = info[:provided_inputs] || info['provided_inputs'] || {}
    provided = IndiferentHash.setup(provided)
    chat = provided[:chat]
    return [] unless String === chat
    endpoint_values(LLM.messages(chat))
  rescue
    []
  end

  def endpoint_values(messages)
    messages.filter_map do |message|
      role = message[:role].to_s
      content = message[:content].to_s.strip
      case role
      when 'endpoint'
        content
      when 'option', 'sticky_option'
        key, _, value = content.partition(/\s+/)
        value.strip if key == 'endpoint'
      end
    end.reject(&:empty?).uniq.sort
  end

  def tool_call_id(message)
    info = JSON.parse(message[:content].to_s)
    info['call_id'] || info['id'] || info.dig('function', 'id')
  rescue
    nil
  end

  def analyze(path)
    parsed = messages(path)
    roles = Hash.new(0)
    parsed.each { |message| roles[message[:role].to_s] += 1 }

    request_events = Chat.usage_events(parsed)
    legacy = Chat.legacy_usage(parsed)
    events = legacy.merge(request_events)
    tools = {}
    parsed.each do |message|
      next unless %w(function_call mcp_call).include?(message[:role].to_s)
      id = tool_call_id(message) || Misc.digest([message[:role], message[:content]])
      tools[id] = true
    end

    {
      path: File.expand_path(path),
      messages: parsed.length,
      roles: roles,
      endpoints: endpoint_values(parsed),
      tools: tools,
      usage: events,
      usage_totals: Chat.usage_totals(events),
      request_events: request_events,
      request_totals: Chat.usage_totals(request_events),
      legacy: legacy,
      legacy_totals: Chat.usage_totals(legacy),
      task_summaries: Chat.usage_summaries(parsed)
    }
  end

  def job_summary(path)
    return {} unless File.file?(path)
    summaries = Chat.usage_summaries(messages(path))
    summaries.values.last || []
  end

  def add_analysis(aggregate, analysis)
    aggregate[:messages] += analysis[:messages]
    analysis[:roles].each { |role, count| aggregate[:roles][role] += count }
    aggregate[:endpoints].merge(analysis[:endpoints])
    aggregate[:tools].merge!(analysis[:tools])
  end

  def format_tokens(values)
    values ||= {}
    "prompt=#{values['pt_c'].to_i} completion=#{values['ct_c'].to_i} total=#{values['tt_c'].to_i}"
  end

  def print_analysis(analysis, indent = '  ')
    puts "#{indent}File: #{analysis[:path]}"
    puts "#{indent}Messages: #{analysis[:messages]}"
    puts "#{indent}Roles: #{analysis[:roles].sort.collect { |role, count| "#{role}=#{count}" }.join(' ')}"
    puts "#{indent}Endpoints: #{analysis[:endpoints].empty? ? '(not recorded)' : analysis[:endpoints].join(', ')}"
    puts "#{indent}Tool calls: #{analysis[:tools].length}"
    puts "#{indent}Request token events: #{analysis[:request_events].length} (#{format_tokens(analysis[:request_totals])})"
    if analysis[:legacy].any?
      puts "#{indent}Legacy cumulative baseline: #{format_tokens(analysis[:legacy_totals])}"
    end
  end

  def print
    discover

    aggregate = {
      messages: 0,
      roles: Hash.new(0),
      endpoints: Set.new,
      tools: {},
      usage: {}
    }

    puts 'Chats'
    puts '====='
    @chat_files.to_a.sort.each do |path|
      analysis = analyze(path)
      print_analysis(analysis)
      add_analysis(aggregate, analysis)
      aggregate[:usage].merge!(analysis[:usage])
      puts
    end

    puts 'Workflow jobs'
    puts '============='
    @jobs.keys.sort.each do |path|
      job = @jobs[path]
      summary = job_summary(path)
      puts "Job: #{path}"
      puts "  Task: #{job[:info][:workflow] || job[:info]['workflow']}##{job[:info][:task_name] || job[:info]['task_name']}"
      puts "  Dependencies: #{Array(job[:info][:dependencies] || job[:info]['dependencies']).length}"
      puts "  Agent logs: #{job[:logs].length}"
      input_endpoints = job_endpoints(job[:info])
      puts "  Input endpoints: #{input_endpoints.empty? ? '(not recorded)' : input_endpoints.join(', ')}"
      aggregate[:endpoints].merge(input_endpoints)
      if summary.empty?
        puts '  Task token delta: (not recorded; aggregate falls back to unique log events)'
      else
        delta = {'pt_c' => summary[0], 'ct_c' => summary[1], 'tt_c' => summary[2]}
        puts "  Task token delta: #{format_tokens(delta)}"
        aggregate[:usage]["job:#{path}"] = summary
      end

      fallback = {}
      job[:logs].each do |log|
        analysis = analyze(log)
        print_analysis(analysis, '    ')
        add_analysis(aggregate, analysis)
        fallback.merge!(analysis[:usage])
      end
      aggregate[:usage].merge!(fallback) if summary.empty?
      puts
    end

    totals = Chat.usage_totals(aggregate[:usage])
    puts 'Aggregate'
    puts '========='
    puts "Objects: chats=#{@chat_files.length} workflow_jobs=#{@jobs.length} agent_logs=#{@jobs.values.sum { |job| job[:logs].length }}"
    puts "Message records: #{aggregate[:messages]}"
    puts "Roles: #{aggregate[:roles].sort.collect { |role, count| "#{role}=#{count}" }.join(' ')}"
    puts "Endpoints: #{aggregate[:endpoints].empty? ? '(not recorded)' : aggregate[:endpoints].to_a.sort.join(', ')}"
    puts "Unique tool calls: #{aggregate[:tools].length}"
    puts "Token usage: #{format_tokens(totals)}"
    puts
    puts 'Notes:'
    puts '- Job token totals use each task summary delta, so dependency totals are not counted repeatedly.'
    puts '- Agent-log pt_c/ct_c/tt_c fields are running snapshots and are never summed.'
    puts '- Endpoint names can only be reported when they were serialized into a chat or agent log.'
  end
end

LLMInfoReport.new(input).print
