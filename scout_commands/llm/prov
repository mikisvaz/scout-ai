def report_line(type, path = nil, info = {}, offset: 0)
  parts = []


  case type
  when :job
    parts << Log.color( :yellow, type.to_s)
  when :chat
    parts << Log.color( :green, type.to_s)
  else
    parts << Log.color( :red, type.to_s)
  end

  if info
    #parts << Log.fingerprint(info) if info
    tok_str ||= []
    tok_str << "total=#{Misc.human_number(info[:tt].to_i)}" if info[:tt]
    tok_str << "prompt=#{Misc.human_number(info[:pt].to_i)}" if info[:pt]
    tok_str << "cont=#{Misc.human_number(info[:ct].to_i)}" if info[:ct]

    parts << tok_str*" "
  end
  parts << Log.color( :blue, path.to_s) if path
  parts.unshift ' '*offset if offset && offset > 0
  parts * " "
end

def report(filename, seen = [], offset: 0, name: nil)
  tokens = Chat.tokens(filename)
  name = File.basename filename if name.nil?

  puts report_line :chat, name, Chat.tokens(filename), offset: offset unless name == 'agent.chat'

  chat = load_chat filename

  chat = Chat.load filename

  chat.jobs.each do |job|
    next if seen.include? job.path
    seen << job.path
    next unless job.done?

    job_tokens = Chat.tokens(job.path) 
    puts report_line :job, job.short_path, job_tokens, offset: offset+1
    Chat.job_agent_chat_files(job).each do |agent_chat|
      agent_name = Misc.path_relative_to job.file('log'), agent_chat
      agent_name.sub(/^(chats|society)\//, '')
      report(agent_chat, seen, offset: offset+1, name: agent_name)
    end
  end
end

