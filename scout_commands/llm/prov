module Chat
  def self.trace(chat_list = @chats.values)
    Chat.trace_chats(chat_list)
  end

  def self.direct_entries(chat_list = @chats.values)
    trace(chat_list).select do |entry|
      meta = entry[:meta]
      next false if meta[:job]
      %w[pt ct tt].any? { |name| meta.include?(name) }
    end
  end

  def self.token_totals(chat_list = @chats.values)
    direct_entries(chat_list).each_with_object({ pt: 0, ct: 0, tt: 0 }) do |entry, totals|
      meta = entry[:meta]
      %w[pt ct tt].each { |name| totals[name.to_sym] += meta[name].to_i }
    end
  end

  def self._format_tokens(tokens)
  end

  def self.print_tokens(tokens)
    "prompt=#{Misc.human_number(tokens[:pt])} completion=#{Misc.human_number(tokens[:ct])} total=#{Misc.human_number(tokens[:tt])}"
  end

  def rec_chats
    chats = [self]
    chats + self.job_chats.inject([]){|acc,job| acc.concat job.rec_agent_chats; acc }
  end
  
  def jobs
    job_paths.collect{|path| Step.load path }
  end

  def self.provenance(chat_file, prov = {})
    return prov if prov.include? chat_file
    return prov unless Open.exists?(chat_file)
    chat = Chat.load chat_file
    chat.jobs.each do |job|
      prov[chat_file] ||= []
      Chat.job_agent_chat_files(job).each do |agent_chat_file|
        prov[chat_file] << agent_chat_file
        prov.merge(Chat.provenance(agent_chat_file, prov))
      end
      job.dependencies.each do |dep|
        prov.merge(Chat.provenance(dep.path, prov))
      end
    end
    prov
  end

  def self.provenance_chat_files(chat)
    provenance(chat).values.flatten.uniq + [chat]
  end

  def self.tokens(chat)
    chats = provenance_chat_files(chat).collect{|file| 
      @@chat_file ||= {}
      @@chat_file[file] ||= LLM.chat file 
      @@chat_file[file] ||= Chat.load file 
    }
    Chat.token_totals(chats)
  end

end

class Step
  def agent_chats
    Chat.job_agent_chat_files(self).collect{|file| Chat.load file }
  end
end

def load_chat(filename)
  @loaded_chat ||= {}
  @loaded_chat[filename] ||= 
    begin
      job = Step.load filename
      filename = job.path if job.done?
      Chat.load filename
    rescue
      Chat.load filename
    end
end

