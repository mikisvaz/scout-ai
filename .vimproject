scout-ai=$PWD filter="*.rb *.rake Rakefile *.rdoc *.R *.sh *.js *.haml *.sass *.txt *.conf" {
 README.md
 USER_GUIDE.md
 Rakefile
 chats=chats filter="*"{
  system=system{
   agent
   scout-ai
  }
  refactor=refactor{
   chat
  }
  help=help{
   fine-tunning
   from_pretrained
   previous_response
  }
  test=test{
   agent_chat.rb
   block
   file
   imports
   imports.rb
   prev
   rf.rb
   tool

   save_reponse

   relay
  }
  web=web{
   chat
   cmd
   web
  }
  develop=develop{
   agent
   agent_system
   causalLM
   chat
   digest
   finetuning
   json_format
   model
   rf
   scout-ai
   training=training{
    basics
    data.tmp
    intro
    python
    data=data{
     main
     next_token
     test.rb
    }
   }
  }

  huggingface

  test_huggingface

  SGLang

 }
 lib=lib {
  scout-ai.rb
  scout=scout{
   network=network{
    paths.rb
    knowledge_base.rb
    entity.rb
   }
   llm=llm{
    utils.rb
    chat.rb
    chat=chat{
     annotation.rb
     parse.rb
     process.rb
     process=process{
      tools.rb
      files.rb
      clear.rb
      options.rb
      meta.rb
     }
    }
    tools.rb
    tools=tools{
     mcp.rb
     workflow.rb
     knowledge_base.rb
     call.rb
    }

    backends=backends{
     default.rb

     responses.rb
     openai.rb
     ollama.rb
     anthropic.rb
     vllm.rb
     huggingface.rb
     openwebui.rb

     bedrock.rb
     relay.rb
    }

    ask.rb

    embed.rb

    rag.rb

    mcp.rb

    agent.rb
    agent=agent{
     chat.rb
     iterate.rb
     delegate.rb
    }
   }
   model=model{
    util=util{
     save.rb
     run.rb
    }
    base.rb

    python=python{
     base.rb
     torch.rb
     torch=torch{
      helpers.rb
      dataloader.rb
      introspection.rb
      load_and_save.rb
     }
     huggingface.rb
     huggingface=huggingface{
      classification.rb
      causal.rb
      causal=causal{
       next_token.rb
      }
     }
    }
   }
  }
 }
 python=python filter="*"{
  scout_ai=scout_ai{
   __init__.py
   agent.py
   chat.py
   data.py
   message.py
   runner.py
   util.py
   huggingface=huggingface{
    data.py
    eval.py
    model.py
    rlhf.py
    train=train{
     __init__.py
     next_token.py
    }
   }
  }
 }
 share=share{
  server=server files="*"{
   chat.html
   chat.js
  }
 }
 doc=doc filter="*"{
  Agent.md
  Chat.md
  LLM.md
  Model.md
 }
 test=test {
  data=data filter="*"{
   person=person{
    identifiers
    brothers
    marriages
    parents
   }
  }
  test_helper.rb
 }
 bin=bin filter="*"{
  scout-ai
 }
 scout_commands=scout_commands filter="*"{
  documenter
  llm=llm{
   ask
   json
   template
   process
   process_queries
   server
  }
  agent=agent{
   ask
   kb
   find
  }
  workflow=workflow{
   mcp
  }
 }
}
